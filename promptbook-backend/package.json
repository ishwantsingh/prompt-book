{
  "name": "promptbook-backend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "prisma generate && next build",
    "start": "next start -p 4000",
    "postinstall": "prisma generate",
    "seed": "echo '🚨 DANGER: This will delete all data! Use npm run seed:safe instead' && exit 1",
    "seed:safe": "tsx scripts/safe-seed.ts",
    "seed:force": "tsx prisma/seed/seed.ts",
    "seed:383": "tsx prisma/seed/seed-with-383-prompts.ts",
    "migrate": "echo '🚨 DANGER: Use npm run migrate:safe instead' && exit 1",
    "migrate:safe": "tsx scripts/safe-migrate.ts",
    "migrate:force": "npx prisma migrate deploy",
    "backup": "tsx scripts/backup-db.ts",
    "restore": "tsx scripts/restore-backup.ts",
    "upsert:official": "tsx scripts/upsert-official-user.ts",
    "post:batch": "tsx scripts/post-batch-prompts.ts",
    "post:missing": "tsx scripts/post-missing-from-batch.ts",
    "import:scores": "tsx scripts/import-manual-scores.ts",
    "delete:seed-prompts": "tsx scripts/delete-seed-prompts.ts",
    "migrate:batch": "tsx scripts/migrate-batch-json.ts",
    "fix-votes": "tsx scripts/fix-vote-counts.ts",
    "sync-votes": "tsx scripts/sync-vote-counts.ts",
    "generate-slugs": "tsx scripts/generate-prompt-slugs.ts",
    "sync:best-scores": "tsx scripts/sync-best-scores.ts",
    "sync:best-scores:all": "tsx scripts/sync-all-best-scores.ts"
  },
  "prisma": {
    "seed": "echo '🚨 DANGER: Direct seeding disabled! Use npm run seed:safe instead' && exit 1"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "^15.5.14",
    "next-auth": "^4.24.12",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@next/eslint-plugin-next": "^15.5.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.34.0",
    "globals": "^16.3.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.4.5"
  }
}
